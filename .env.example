# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=oaadrive
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=oaadrive
DATABASE_URL=postgres://oaadrive:changeme_strong_password@localhost:5432/oaadrive?sslmode=disable

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=changeme_minio_access_key
MINIO_SECRET_KEY=changeme_minio_secret_key
MINIO_USE_TLS=false

# ─── Migrations ───────────────────────────────────────────────────────────────
MIGRATIONS_PATH=./migrations
